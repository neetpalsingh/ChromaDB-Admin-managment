# ChromaDB Dashboard - Environment Configuration Example
# Copy this file to .env and update with your actual values

# ==========================================
# ChromaDB Configuration
# ==========================================

# ChromaDB Server URL (without trailing slash)
# This is the URL where your ChromaDB instance is running
VITE_CHROMADB_URL=http://localhost:8000
CHROMADB_URL=http://localhost:8000

# ==========================================
# Application URLs
# ==========================================

# Frontend Application URL (where the dashboard is hosted)
VITE_APP_URL=http://localhost:3434

# Admin/Dashboard URL (for CORS and proxy headers)
VITE_ADMIN_URL=http://localhost:3434

# ==========================================
# Server Ports
# ==========================================

# Main application port (default: 3434)
PORT=3434
VITE_PORT=3434

# Tenant file server port
TENANT_SERVER_PORT=3436

# ==========================================
# Application Settings
# ==========================================

NODE_ENV=development
VITE_APP_TITLE=ChromaDB Dashboard
VITE_APP_VERSION=1.0.0

# Enable/disable source maps in build
GENERATE_SOURCEMAP=false

# ==========================================
# API Endpoints
# ==========================================

# API base path (relative to frontend)
VITE_API_BASE_URL=/api

# Tenant API URL
VITE_TENANT_API_URL=http://localhost:3004/api/tenants

# ==========================================
# Security Settings (Optional)
# ==========================================

# Uncomment and set these if your ChromaDB requires authentication
# VITE_API_KEY=your-api-key-here
# VITE_AUTH_ENABLED=false
# VITE_AUTH_TOKEN=your-auth-token-here

# ==========================================
# CORS Settings
# ==========================================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3434,http://localhost:3435

# ==========================================
# Production Settings
# ==========================================

# For production deployment, uncomment and update these:
# VITE_CHROMADB_URL=https://your-chromadb-instance.com
# CHROMADB_URL=https://your-chromadb-instance.com
# VITE_APP_URL=https://your-dashboard-domain.com
# VITE_ADMIN_URL=https://your-dashboard-domain.com
# NODE_ENV=production
# CORS_ORIGINS=https://your-dashboard-domain.com

# ==========================================
# Notes
# ==========================================

# 1. VITE_ prefixed variables are exposed to the frontend code
# 2. Non-VITE_ variables are only available in Node.js server code
# 3. Never commit your actual .env file to version control
# 4. Always keep .env.example updated with all required variables
# 5. Restart the development server after changing environment variables
